# ECP Backend — Environment Variables
# Copy to .env and fill in values

# Server
PORT=8000
ECP_BASE_URL=https://api.llachat.com
LLACHAT_URL=https://llachat.com
ALLOWED_ORIGINS=https://llachat.com,https://weba0.com

# Database
ECP_DB_PATH=ecp.db          # Use :memory: for tests

# EAS on Base (Phase 2 — Week 9-10)
EAS_MODE=stub               # "stub" for dev, "live" for production
ECP_SCHEMA_UID=             # Set after registering schema on EAS
ATLAST_PRIVATE_KEY=         # ATLAST Safe multisig private key (NEVER commit this)
