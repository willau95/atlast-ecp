{
  "id": "atlast-ecp",
  "name": "ATLAST ECP",
  "description": "Evidence Chain Protocol — passive trust recording for AI agents. Captures every LLM interaction and uploads Merkle-anchored batches.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiUrl": {
        "type": "string",
        "description": "ATLAST API endpoint (default: https://api.llachat.com/v1)"
      },
      "apiKey": {
        "type": "string",
        "description": "Agent API key (ak_live_xxx) for authenticated uploads"
      },
      "agentName": {
        "type": "string",
        "description": "Display name for this agent (optional)"
      },
      "batchIntervalMs": {
        "type": "number",
        "description": "Batch upload interval in ms (default: 3600000 = 1 hour)"
      },
      "ecpDir": {
        "type": "string",
        "description": "Local ECP storage directory (default: ~/.ecp)"
      },
      "enabled": {
        "type": "boolean",
        "description": "Enable/disable ECP recording (default: true)"
      }
    }
  },
  "uiHints": {
    "apiKey": { "label": "Agent API Key", "sensitive": true, "placeholder": "ak_live_xxx" },
    "apiUrl": { "label": "API URL", "placeholder": "https://api.llachat.com/v1" },
    "agentName": { "label": "Agent Name", "placeholder": "my-agent" }
  }
}
