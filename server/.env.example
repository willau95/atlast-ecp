# ATLAST ECP Server — Environment Variables
# Copy to .env and fill in values

# ── EAS (Ethereum Attestation Service) ──
EAS_PRIVATE_KEY=           # Wallet private key for signing attestations
EAS_SCHEMA_UID=0xa67da7e880b3fe643f0e12b754c6048fc0a0bad0ed9a932ac85a5ebf6bd9326e
EAS_CHAIN=sepolia          # "sepolia" (testnet) or "mainnet" (Base mainnet)
EAS_STUB_MODE=true         # REQUIRED in non-dev: "true" = stub (dev/testing), "false" = real on-chain (also needs EAS_PRIVATE_KEY). Non-dev startup fails if unset.
BASE_RPC_URL=              # Optional: custom Base RPC (default: mainnet.base.org)

# ── Webhook (push notifications to platforms) ──
ECP_WEBHOOK_URL=           # Platform webhook endpoint (e.g., https://your-platform.com/webhook)
ECP_WEBHOOK_TOKEN=         # Shared secret for HMAC signing

# ── Platform Integration (optional) ──
PLATFORM_API_URL=          # Platform API for service-to-service calls
LLACHAT_INTERNAL_TOKEN=    # Internal auth token (if platform uses internal endpoints)

# ── Discord Notifications ──
ATLAST_DISCORD_WEBHOOK=            # Discord webhook for bug reports / alerts
ATLAST_DISCORD_NEW_USERS_WEBHOOK=  # Discord webhook for new user notifications

# ── Database ──
DATABASE_URL=              # PostgreSQL connection string

# ── Server ──
PORT=8080
ENVIRONMENT=development    # "development" or "production"

# ── Anchor Scheduling ──
ANCHOR_INTERVAL_MINUTES=60
SUPER_BATCH_MIN_SIZE=10       # Min batches to super-merge into one on-chain tx
MIN_ANCHOR_BATCHES=10         # Anchor gate: min pending batches
MIN_ANCHOR_RECORDS=100        # Anchor gate: min total records across pending batches
MAX_ANCHOR_WAIT_HOURS=168     # Anti-starvation: force anchor if oldest batch waited this long (default 7 days)

# ── Monitoring ──
SENTRY_DSN=                # Sentry DSN for error tracking (optional)
